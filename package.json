{
  "name": "weixin-household-agent-acp",
  "version": "0.1.0",
  "private": true,
  "description": "WeChat household Codex gateway",
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "build": "tsc -p apps/server/tsconfig.json",
    "build:watch": "tsc -p apps/server/tsconfig.json --watch",
    "check": "tsc -p apps/server/tsconfig.json --noEmit",
    "start": "node dist/apps/server/index.js",
    "dev": "node --enable-source-maps --watch dist/apps/server/index.js"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "typescript": "^5.9.3"
  }
}
